{
  "name": "@f2b/spec",
  "version": "0.1.0",
  "description": "F2B / 灵境云跨产品契约（OpenAPI · 错误码 · TS 类型）",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./errors": "./src/errors.ts",
    "./sandbox": "./src/sandbox.ts",
    "./tunnel": "./src/tunnel.ts"
  },
  "files": [
    "src",
    "openapi",
    "errors",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check:errors": "node scripts/check-error-codes.mjs",
    "lint:openapi": "spectral lint openapi/sandbox-v1.yaml openapi/tunnel-v1.yaml",
    "ci": "pnpm typecheck && pnpm check:errors && pnpm lint:openapi",
    "pack:check": "bash scripts/pack-check.sh"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "6.16.2",
    "typescript": "^7.0.2"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/f2b-dev/f2b-spec.git"
  }
}
